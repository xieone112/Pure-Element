{
  "name": "@xieone/pure-element",
  "version": "1.0.0",
  "type": "module",
  "author": {
    "name": "xieone"
  },
  "license": "MIT",
  "keywords": [
    "component",
    "UI",
    "vue"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xieone112/Pure-Element.git"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/index.css"
  ],
  "types": "./dist/types/index.d.ts",
  "main": "./dist/PureElement.umd.cjs",
  "module": "./dist/es/PureElement.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/PureElement.js",
      "require": "./dist/PureElement.umd.cjs"
    },
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build-only && npm run move-style",
    "preview": "vite preview",
    "build-only": "run-p build-umd build-es",
    "build-umd": "vite build --config vite.umd.config.ts",
    "build-es": "vite build --config vite.es.config.ts",
    "move-style": "move-file dist/es/PureElement.css dist/index.css",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "test": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@popperjs/core": "^2.11.8",
    "@vitepress-demo-preview/component": "^2.6.2",
    "@vitepress-demo-preview/plugin": "^1.4.1",
    "async-validator": "^4.2.5",
    "lodash-es": "^4.17.23",
    "move-file-cli": "^3.0.0"
  },
  "peerDependencies": {
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitepress": "^1.5.0",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.5",
    "vue": "^3.5.29"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}